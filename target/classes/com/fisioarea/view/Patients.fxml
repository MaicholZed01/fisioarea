<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1240.0" styleClass="dashboard-background" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fisioarea.controller.PatientsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar">
            <padding>
                <Insets bottom="18.0" left="28.0" right="28.0" top="18.0" />
            </padding>

            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label styleClass="dashboard-title" text="Pazienti" />
                        <Label styleClass="dashboard-subtitle" text="Anagrafica, scheda clinica e archivio file offline" />
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#handleBackToDashboard" styleClass="ghost-button" text="Torna alla dashboard" />
                <Button mnemonicParsing="false" onAction="#handleAddPatient" styleClass="primary-button-compact" text="+ Nuovo paziente" />
            </children>
        </HBox>
    </top>

    <center>
        <HBox spacing="18.0" styleClass="dashboard-content">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <children>
                <VBox spacing="18.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label styleClass="section-title-large" text="Lista pazienti" />
                                        <Label styleClass="section-subtitle" text="Clicca su un paziente per aprire la scheda clinica completa." />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <TextField fx:id="searchField" prefWidth="360.0" promptText="Cerca paziente, telefono, email o indirizzo..." styleClass="search-field" />
                            </children>
                        </HBox>

                        <TableView fx:id="patientsTable" prefHeight="500.0" styleClass="clean-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="nameColumn" prefWidth="190.0" text="Nome e cognome" />
                                <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="Telefono" />
                                <TableColumn fx:id="emailColumn" prefWidth="210.0" text="Email" />
                                <TableColumn fx:id="addressColumn" prefWidth="260.0" text="Indirizzo casa" />
                                <TableColumn fx:id="filesColumn" prefWidth="90.0" text="File" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label fx:id="statusLabel" styleClass="success-label" text="Pazienti: 0" />

                                <Region HBox.hgrow="ALWAYS" />

                                <Button fx:id="editButton" mnemonicParsing="false" onAction="#handleEditPatient" styleClass="ghost-button" text="Modifica selezionato" />
                                <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDeletePatient" styleClass="danger-button" text="Elimina selezionato" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>
</BorderPane>
