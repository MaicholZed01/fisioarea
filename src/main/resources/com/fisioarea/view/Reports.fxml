<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1240.0"
            stylesheets="@styles.css"
            styleClass="dashboard-background"
            xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fisioarea.controller.ReportController">

    <left>
        <VBox prefWidth="260.0" spacing="22.0" styleClass="sidebar">
            <padding>
                <Insets bottom="26.0" left="22.0" right="22.0" top="26.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="F" styleClass="brand-mark-small" />
                        <VBox spacing="0.0">
                            <children>
                                <Label text="Fisioarea" styleClass="brand-title-dark" />
                                <Label text="Studio manager" styleClass="brand-subtitle-dark" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="8.0">
                    <children>
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Dashboard" onAction="#handleOpenDashboard" styleClass="nav-button" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Report" styleClass="nav-button-active" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Pazienti" onAction="#handleOpenPatients" styleClass="nav-button" />
                        <Button fx:id="adminUsersButton" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Gestione utenti" onAction="#handleOpenUserManagement" styleClass="nav-button" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Profilo" onAction="#handleOpenProfile" styleClass="nav-button" />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12.0" styleClass="sidebar-card">
                    <children>
                        <Label text="Report studio" styleClass="sidebar-card-label" />
                        <Label text="Andamento pazienti" styleClass="sidebar-card-title" />
                        <Label text="Analizza pazienti giornalieri, settimanali e mensili dagli appuntamenti salvati offline."
                               wrapText="true" styleClass="sidebar-card-text" />
                    </children>
                </VBox>

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                        text="  Esci" onAction="#handleLogout" styleClass="nav-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar">
            <padding>
                <Insets bottom="18.0" left="28.0" right="28.0" top="18.0" />
            </padding>

            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Report pazienti" styleClass="dashboard-title" />
                        <Label text="Conteggi e andamento giornaliero dei pazienti" styleClass="dashboard-subtitle" />
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" text="Oggi" onAction="#handleToday" styleClass="ghost-button" />
                <Button mnemonicParsing="false" text="‹" onAction="#handlePreviousDay" styleClass="calendar-nav-button" />
                <Button mnemonicParsing="false" text="›" onAction="#handleNextDay" styleClass="calendar-nav-button" />

                <DatePicker fx:id="reportDatePicker" styleClass="date-picker-clean" />

                <HBox alignment="CENTER" spacing="10.0" onMouseClicked="#handleOpenProfile" styleClass="user-chip">
                    <children>
                        <Label text="MC" styleClass="avatar" />
                        <VBox spacing="0.0">
                            <children>
                                <Label fx:id="welcomeLabel" text="Profilo" styleClass="user-name" />
                                <Label text="Apri profilo" styleClass="user-role" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-main-scroll">
            <content>
                <VBox spacing="26.0" styleClass="dashboard-content">
                    <padding>
                        <Insets bottom="32.0" left="28.0" right="28.0" top="28.0" />
                    </padding>

                    <children>
                        <VBox spacing="22.0" styleClass="dashboard-section-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <VBox spacing="3.0">
                                            <children>
                                                <Label text="Report pazienti" styleClass="section-title-large" />
                                                <Label text="Conteggi dei pazienti distinti basati sugli appuntamenti salvati offline."
                                                       styleClass="section-subtitle" />
                                            </children>
                                        </VBox>

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Label fx:id="reportPeriodLabel" text="Periodo" styleClass="report-period-chip" />
                                    </children>
                                </HBox>

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="8.0" styleClass="report-stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Pazienti giornalieri" styleClass="report-stat-label" />
                                                <Label fx:id="dailyPatientsValueLabel" text="0" styleClass="report-stat-value" />
                                                <Label text="Nel giorno selezionato" styleClass="report-stat-caption" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0" styleClass="report-stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Pazienti settimanali" styleClass="report-stat-label" />
                                                <Label fx:id="weeklyPatientsValueLabel" text="0" styleClass="report-stat-value" />
                                                <Label text="Da lunedì a domenica" styleClass="report-stat-caption" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0" styleClass="report-stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Pazienti mensili" styleClass="report-stat-label" />
                                                <Label fx:id="monthlyPatientsValueLabel" text="0" styleClass="report-stat-value" />
                                                <Label text="Nel mese selezionato" styleClass="report-stat-caption" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="12.0" styleClass="report-chart-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <VBox spacing="3.0">
                                                    <children>
                                                        <Label text="Grafico lineare" styleClass="section-title-large" />
                                                        <Label fx:id="reportChartSubtitleLabel"
                                                               text="Andamento giornaliero dei pazienti nel mese selezionato"
                                                               styleClass="section-subtitle" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <LineChart fx:id="patientsLineChart" animated="false" createSymbols="true"
                                                   legendVisible="false" horizontalGridLinesVisible="true"
                                                   verticalGridLinesVisible="false" prefHeight="360.0"
                                                   styleClass="report-line-chart">
                                            <xAxis>
                                                <CategoryAxis label="Giorno" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis label="Pazienti" autoRanging="true" forceZeroInRange="true" />
                                            </yAxis>
                                        </LineChart>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
