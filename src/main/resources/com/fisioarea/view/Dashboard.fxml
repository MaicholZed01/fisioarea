<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1240.0"
            stylesheets="@styles.css"
            styleClass="dashboard-background"
            xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fisioarea.controller.DashboardController">

    <left>
        <VBox prefWidth="260.0" spacing="22.0" styleClass="sidebar">
            <padding>
                <Insets bottom="26.0" left="22.0" right="22.0" top="26.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="F" styleClass="brand-mark-small" />
                        <VBox spacing="0.0">
                            <children>
                                <Label text="Fisioarea" styleClass="brand-title-dark" />
                                <Label text="Studio manager" styleClass="brand-subtitle-dark" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="8.0">
                    <children>
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Dashboard" styleClass="nav-button-active" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Report" onAction="#handleOpenReports" styleClass="nav-button" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Pazienti" onAction="#handleOpenPatients" styleClass="nav-button" />
                        <Button fx:id="adminUsersButton" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Gestione utenti" onAction="#handleOpenUserManagement" styleClass="nav-button" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                                text="  Profilo" onAction="#handleOpenProfile" styleClass="nav-button" />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12.0" styleClass="sidebar-card">
                    <children>
                        <Label text="Agenda studio" styleClass="sidebar-card-label" />
                        <Label text="Gestione appuntamenti" styleClass="sidebar-card-title" />
                        <Label text="Organizza appuntamenti, modifica le sedute ed esporta i dati in Excel."
                               wrapText="true" styleClass="sidebar-card-text" />
                    </children>
                </VBox>

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                        text="  Esci" onAction="#handleLogout" styleClass="nav-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar">
            <padding>
                <Insets bottom="18.0" left="28.0" right="28.0" top="18.0" />
            </padding>

            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Dashboard" styleClass="dashboard-title" />
                        <Label text="Agenda appuntamenti e gestione sedute" styleClass="dashboard-subtitle" />
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="globalSearchField" promptText="Cerca paziente, trattamento, stato..."
                           prefWidth="320.0" styleClass="search-field" />

                <HBox alignment="CENTER" spacing="10.0" onMouseClicked="#handleOpenProfile" styleClass="user-chip">
                    <children>
                        <Label text="MC" styleClass="avatar" />
                        <VBox spacing="0.0">
                            <children>
                                <Label fx:id="welcomeLabel" text="Profilo" styleClass="user-name" />
                                <Label text="Apri profilo" styleClass="user-role" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-main-scroll">
            <content>
                <VBox spacing="26.0" styleClass="dashboard-content">
                    <padding>
                        <Insets bottom="32.0" left="28.0" right="28.0" top="28.0" />
                    </padding>

                    <children>
                        <VBox spacing="22.0" styleClass="dashboard-section-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <VBox spacing="3.0">
                                            <children>
                                                <Label fx:id="calendarTitleLabel" text="Agenda" styleClass="section-title-large" />
                                                <Label text="Visualizza e gestisci gli appuntamenti del giorno selezionato."
                                                       styleClass="section-subtitle" />
                                            </children>
                                        </VBox>

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Button mnemonicParsing="false" text="Oggi" onAction="#handleToday" styleClass="ghost-button" />
                                        <Button mnemonicParsing="false" text="‹" onAction="#handlePreviousDay" styleClass="calendar-nav-button" />
                                        <Button mnemonicParsing="false" text="›" onAction="#handleNextDay" styleClass="calendar-nav-button" />
                                        <DatePicker fx:id="agendaDatePicker" styleClass="date-picker-clean" />
                                        <Button mnemonicParsing="false" text="Esporta Excel" onAction="#handleExportAppointmentsToExcel"
                                                styleClass="ghost-button" />
                                        <Button mnemonicParsing="false" text="+ Nuovo appuntamento" onAction="#handleNewAppointment"
                                                styleClass="primary-button-compact" />
                                    </children>
                                </HBox>

                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="590.0" styleClass="calendar-scroll">
                                    <content>
                                        <GridPane fx:id="calendarGrid" hgap="0.0" vgap="10.0" styleClass="calendar-grid" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
